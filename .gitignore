# ============================================
#   FarmSense AI — .gitignore
# ============================================


# ============================================
# 🔐 ENVIRONMENT VARIABLES (NEVER commit these)
# ============================================
.env
.env.local
.env.development
.env.production
.env.test
*.env
server/.env
ai-engine/.env
client/.env


# ============================================
# 🟢 NODE.JS (server/)
# ============================================
node_modules/
server/node_modules/
client/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.node_repl_history


# ============================================
# 🐍 PYTHON / DJANGO (ai-engine/)
# ============================================

# Virtual Environment
venv/
env/
.venv/
ai-engine/venv/
ai-engine/env/
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Django specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# Django migrations (optional — some teams commit these)
# Uncomment below if you don't want to commit migrations:
# */migrations/*.py
# !*/migrations/__init__.py

# Celery
celerybeat-schedule
celerybeat.pid


# ============================================
# 🤖 ML MODELS & DATA (large files)
# ============================================
ai-engine/ml_models/*.pkl
ai-engine/ml_models/*.joblib
ai-engine/ml_models/*.h5
ai-engine/ml_models/*.model
*.pkl
*.joblib
*.h5
*.model
*.npy
*.npz

# Training data & notebooks (usually large)
ai-engine/data/raw/
*.csv
!ai-engine/data/crops_sample.csv
*.xlsx
*.json
!ai-engine/data/crops.json

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/
*.ipynb


# ============================================
# ⚛️ REACT (client/)
# ============================================
client/dist/
client/build/
client/.vite/
.vite/
dist/
build/


# ============================================
# 🗄️ DATABASE
# ============================================
*.sql
*.sqlite
*.sqlite3
*.db
pg_dump/
database_backups/


# ============================================
# 🖥️ OPERATING SYSTEM
# ============================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*


# ============================================
# 💻 VS CODE & EDITORS
# ============================================
.vscode/
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.classpath
.settings/


# ============================================
# 📦 MISCELLANEOUS
# ============================================

# Logs
logs/
*.log
log/

# Coverage reports
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# Cache
.cache/
.parcel-cache/
*.cache

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# Upload folders (user uploaded files)
uploads/
server/uploads/

# SSL certificates
*.pem
*.key
*.crt
*.cert

# Docker (if used later)
.dockerignore
docker-compose.override.yml